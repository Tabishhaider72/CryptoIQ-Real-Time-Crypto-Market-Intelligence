{
  "name": "crypto-market",
  "version": "0.1.0",
  "private": true,

  "scripts": {
  "dev": "concurrently \"pnpm next\" \"pnpm socket\" \"pnpm worker\"",
  "dev:all": "concurrently \"pnpm start\" \"pnpm socket\" \"pnpm worker\"",
  "next": "next dev",
  "socket": "tsx --tsconfig tsconfig.json backend/socketServer.ts",
  "worker": "tsx --tsconfig tsconfig.json backend/workers/priceWorker.ts",
  "build": "prisma generate && next build",
  "start": "next start",
  "lint": "eslint"
},

  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "7.8.0",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.39.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.16.0",
    "motion": "^12.39.0",
    "next": "16.2.6",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.7.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },

  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/axios": "^0.14.4",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
